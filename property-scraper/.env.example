# PostgreSQL connection (reuse the existing myinfoapp database on the droplet).
# Local example:
#   DATABASE_URL=postgres://postgres:password@localhost:5432/myinfoapp
# On the droplet the app connects as the local postgres role.
DATABASE_URL=postgres://postgres:password@localhost:5432/myinfoapp

# HTTP server port (localhost-only). 3000 is used by the existing myapp service.
PORT=3001

# Resync batch tuning.
# RESYNC_LIMIT: max properties per run. Empty/0 = ALL properties (default).
RESYNC_LIMIT=0
# Delay between property fetches, in milliseconds (be polite to the source site).
RESYNC_DELAY_MS=1000
# Number of properties to scrape in parallel. Keep low (1-4).
RESYNC_CONCURRENCY=1
